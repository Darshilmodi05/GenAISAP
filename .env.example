# ==============================================================================
# GenAISAP - Enterprise Configuration Template
# ==============================================================================

# ─── 1. Next.js App Core ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── 2. Supabase (Database, Auth, Storage) ────────────────────────────────────
# Get these from your Supabase project dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── 3. AI & Reasoning Engine ─────────────────────────────────────────────────
# Anthropic Claude API for primary reasoning
ANTHROPIC_API_KEY=your-anthropic-api-key
# OpenAI API for embeddings and vector search
OPENAI_API_KEY=your-openai-api-key

# ─── 4. ML Microservice (FastAPI) ─────────────────────────────────────────────
# Local development URL. Update for production.
ML_SERVICE_URL=http://localhost:8000
# Optional: API key if the ML service is secured
ML_SERVICE_API_KEY=your-ml-service-api-key

# ─── 5. SAP Integration ───────────────────────────────────────────────────────
# Default mock/demo instance or real S/4HANA OData endpoint
SAP_DEFAULT_INSTANCE_URL=https://s4hana-mock.sap.corp
# Secret used to verify incoming SAP webhooks in Edge Functions
SAP_WEBHOOK_SECRET=your-webhook-secret

# ─── 6. Redis / Caching (Upstash) ─────────────────────────────────────────────
# For rate limiting and background queues
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── 7. Telemetry & Monitoring (PostHog & Sentry) ─────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
